  const today=new Date();today.setHours(0,0,0,0);
  const liveD=safeDate(p.liveETA);
  const isOvd=liveD&&liveD<today&&p.status!=='Live'&&!FROZEN.includes(p.status);
  const updates=(p.weeklyUpdates||[]).slice().reverse().map(u=>{const ut=typeof u==='object'?(u.content||u.text||''):String(u);const ud=typeof u==='object'?u.date||'':'';return'<div class="upd-item"><div>'+ut+'</div><div class="upd-meta">'+ud+'</div></div>';}).join('');
  return'<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;"><div>'+
    '<div class="info-row"><span class="info-lbl">Priority</span><span class="badge '+pCls(p.priority)+'">'+p.priority+'</span></div>'+
    '<div class="info-row"><span class="info-lbl">Status</span><span class="badge '+sCls(p.status)+'">'+p.status+'</span></div>'+
    '<div class="info-row"><span class="info-lbl">PM</span><span>'+(p.pm||'—')+'</span></div>'+
