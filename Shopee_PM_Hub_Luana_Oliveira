const STORE='sph_v3',STORE_TEAM='sph_team3',STORE_TASKS='sph_tasks3',STORE_SESSION='sph_session';
function loadP(){try{const d=JSON.parse(localStorage.getItem(STORE));if(d&&d.length)return d;}catch(e){}return JSON.parse(JSON.stringify(SEED));}
function saveP(){localStorage.setItem(STORE,JSON.stringify(projects));}
function loadT(){
  try{const d=JSON.parse(localStorage.getItem(STORE_TEAM));if(d&&d.length){
    // Backfill emails from SEED_TEAM for members that have empty email
    d.forEach(m=>{if(!m.email){const seed=SEED_TEAM.find(s=>s.id===m.id||s.name===m.name);if(seed&&seed.email)m.email=seed.email;}});
    // Remove Marcos L. if still present (legacy cleanup)
    const filtered=d.filter(m=>m.name!=='Marcos L.'&&m.id!=='tm8');
    // Inject new seed members not yet in stored data
    SEED_TEAM.forEach(s=>{if(!filtered.find(m=>m.id===s.id||m.name===s.name))filtered.push(JSON.parse(JSON.stringify(s)));});
    return filtered;
  }}catch(e){}return JSON.parse(JSON.stringify(SEED_TEAM));
}
function saveT(){localStorage.setItem(STORE_TEAM,JSON.stringify(team));}
function loadTasks(){try{return JSON.parse(localStorage.getItem(STORE_TASKS))||[];}catch(e){return[];}}
function saveTasks(){localStorage.setItem(STORE_TASKS,JSON.stringify(tasks));}

