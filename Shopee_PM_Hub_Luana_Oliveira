// ── BOARD VIEW ──
let boardDragId=null;
function renderBoard(filtered){
  const board=document.getElementById('proj-board');if(!board)return;
  if(!filtered.length){board.innerHTML=emptyState('📭','No projects found','Try adjusting your filters.','clearAllFilters()','Clear Filters');return;}
  const active=filtered.filter(p=>!FROZEN.includes(p.status));
  const frozen=filtered.filter(p=>FROZEN.includes(p.status));
  const validSet=new Set(STAGES);
  const other=active.filter(p=>!validSet.has(p.status));
  const main=active.filter(p=>validSet.has(p.status));
  const cols=STAGES.map(stage=>{
    const cards=main.filter(p=>p.status===stage);
    const html=cards.map((p,i)=>'<div class="bcard" draggable="true" data-id="'+p.id+'" style="animation-delay:'+i*25+'ms" onclick="openModal(\''+p.id+'\')" onmousedown="event.stopPropagation()">'+
      '<div class="bcard-name">'+esc(p.initiative||'—')+'</div>'+
      '<div class="bcard-meta"><span class="badge '+pCls(p.priority)+'" style="font-size:9px;padding:1px 5px">'+p.priority+'</span><span class="bcard-pm">'+(p.pm||'—')+'</span><span class="bcard-eta">'+fmtD(p.liveETA)+'</span></div>'+
      '</div>').join('');
    return'<div class="board-col" data-stage="'+stage+'" ondragover="boardDragOver(event)" ondrop="boardDrop(event,\''+stage+'\')" ondragleave="boardDragLeave(event)">'+
      '<div class="board-col-hd"><span>'+stage+'</span><span class="bc-cnt">'+cards.length+'</span></div>'+
      '<div class="board-cards">'+(html||'<div class="board-empty-col">Drag projects here</div>')+'</div></div>';
  });
  const frozenHtml=frozen.length?'<div class="board-col"><div class="board-col-hd" style="color:var(--gr)"><span>🧊 Frozen ('+frozen.length+')</span></div><div class="board-cards">'+frozen.map(p=>'<div class="bcard frozen-card" onclick="openModal(\''+p.id+'\')"><div class="bcard-name">'+esc(p.initiative||'—')+'</div><div class="bcard-meta"><span class="badge '+pCls(p.priority)+'" style="font-size:9px;padding:1px 5px">'+p.priority+'</span></div></div>').join('')+'</div></div>':'';
  board.innerHTML=cols.join('')+(other.length?'<div class="board-col"><div class="board-col-hd" style="color:var(--dg)"><span>⚠️ Other</span></div><div class="board-cards">'+other.map(p=>'<div class="bcard" onclick="openModal(\''+p.id+'\')"><div class="bcard-name">'+esc(p.initiative||'—')+'</div></div>').join('')+'</div></div>':'')+frozenHtml;
  board.querySelectorAll('.bcard[draggable]').forEach(c=>{
    c.addEventListener('dragstart',e=>{boardDragId=c.dataset.id;e.dataTransfer.setData('text/plain',c.dataset.id);c.classList.add('dragging');});
    c.addEventListener('dragend',()=>{c.classList.remove('dragging');boardDragId=null;});
  });
}
function boardDragOver(e){e.preventDefault();e.currentTarget.classList.add('drag-over');}
function boardDragLeave(e){e.currentTarget.classList.remove('drag-over');}
function boardDrop(e,stage){e.preventDefault();e.currentTarget.classList.remove('drag-over');const id=e.dataTransfer.getData('text/plain')||boardDragId;const p=projects.find(x=>x.id===id);if(p&&p.status!==stage){p.status=stage;saveP();renderProjects();toast('Moved to '+stage,'success');}}

