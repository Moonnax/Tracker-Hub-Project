// ── HEATMAP ──
function renderHeatmap(){
  const el=document.getElementById('hm-body');if(!el)return;
  const pms=[...new Set(projects.map(p=>p.pm).filter(Boolean))].sort();
  const today=new Date();const months=[];
  for(let i=-1;i<=13;i++){const d=new Date(today.getFullYear(),today.getMonth()+i,1);months.push(d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0'));}
  const curMK=today.getFullYear()+'-'+String(today.getMonth()+1).padStart(2,'0');
  const matrix={};
  projects.forEach(p=>{if(!p.pm)return;let sD=safeDate(p.localETA),eD=safeDate(p.liveETA);if(!eD)return;if(!sD)sD=eD;const cur=new Date(sD.getFullYear(),sD.getMonth(),1);const end=new Date(eD.getFullYear(),eD.getMonth(),1);while(cur<=end){const mk=cur.getFullYear()+'-'+String(cur.getMonth()+1).padStart(2,'0');if(!matrix[p.pm])matrix[p.pm]={};if(!matrix[p.pm][mk])matrix[p.pm][mk]=[];if(!matrix[p.pm][mk].includes(p))matrix[p.pm][mk].push(p);cur.setMonth(cur.getMonth()+1);}});
  const totals={};months.forEach(mk=>{totals[mk]=0;pms.forEach(pm=>{totals[mk]+=(matrix[pm]?.[mk]||[]).length;});});
  function hC(n){const isDk=document.body.classList.contains('dark-mode');return!n?(isDk?'var(--bg-card)':'#fff'):n===1?'#FFF3F0':n===2?'#FCA486':n<=4?'#F27961':n<=7?'#EE4D2D':'#D3422A';}
  function tc(n){return n>=3?'#fff':n?'#B91C1C':'';}
  const hdrs=months.map(mk=>'<th class="hm-hd'+(mk===curMK?' cur':'')+'" style="'+(mk===curMK?'background:var(--ord)':'')+' ">'+mLabel(mk)+'</th>').join('');
  const pmRows=pms.map(pm=>'<tr><td class="hm-pm">'+esc(pm)+'</td>'+months.map(mk=>{const ps=matrix[pm]?.[mk]||[];const n=ps.length;const tip='<strong>'+mLabel(mk)+'</strong><br>'+esc(pm)+': '+n+' project'+(n!==1?'s':'')+(ps.length?'<br>'+ps.map(p=>esc(p.initiative)).slice(0,5).join('<br>')+(ps.length>5?'<br>+('+(ps.length-5)+' more)':''):'');return'<td class="hm-cell" style="background:'+hC(n)+';color:'+tc(n)+';"><span>'+(n||'')+'</span><div class="hm-tip">'+tip+'</div></td>';}).join('')+'</tr>').join('');
  const totalRow='<tr class="hm-total"><td class="hm-pm">TOTAL</td>'+months.map(mk=>'<td class="hm-cell">'+(totals[mk]||'')+'</td>').join('')+'</tr>';
  el.innerHTML='<table class="hm-tbl"><thead><tr><th class="hm-hd hm-pm-hd">PM</th>'+hdrs+'</tr></thead><tbody>'+pmRows+totalRow+'</tbody></table>';
}

