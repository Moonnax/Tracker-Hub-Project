// Simulated time-per-project data (hours) keyed by projectId+pmName
function getTimeData(projList){
  // Use deterministic pseudorandom hours based on project id for realistic demo data
  return projList.map(p=>{
    let hash=0;for(let i=0;i<(p.id||'').length;i++){hash=(hash*31+p.id.charCodeAt(i))>>>0;}
    const hrs=10+(hash%55);
    return{id:p.id,name:(p.initiative||'—').slice(0,18),pm:p.pm||'',hrs};
  });
}
// Pie chart SVG builder
function buildPieChart(slices,size){
  // slices: [{label,value,color}]
  const total=slices.reduce((s,x)=>s+x.value,0);if(!total)return'<div class="text-muted" style="padding:20px 0;text-align:center;">No data</div>';
  const r=size/2-4;const cx=size/2;const cy=size/2;
  let startAngle=-Math.PI/2;
  const paths=slices.map((s,i)=>{
    const angle=2*Math.PI*(s.value/total);
    const x1=cx+r*Math.cos(startAngle);const y1=cy+r*Math.sin(startAngle);
    const x2=cx+r*Math.cos(startAngle+angle);const y2=cy+r*Math.sin(startAngle+angle);
    const large=angle>Math.PI?1:0;
    const pct=Math.round(s.value/total*100);
    // Mid-angle for label
    const mid=startAngle+angle/2;
    const lx=cx+(r*0.62)*Math.cos(mid);const ly=cy+(r*0.62)*Math.sin(mid);
    const path=`M${cx},${cy} L${x1},${y1} A${r},${r} 0 ${large},1 ${x2},${y2} Z`;
    startAngle+=angle;
    return`<path d="${path}" fill="${s.color}" stroke="#fff" stroke-width="2">
      <title>${s.label}: ${s.value}h (${pct}%)</title></path>`+
      (pct>=7?`<text x="${lx}" y="${ly}" text-anchor="middle" dominant-baseline="middle" fill="#fff" font-size="9" font-weight="700" pointer-events="none">${s.value}h</text>`:'');
  }).join('');
  return`<svg viewBox="0 0 ${size} ${size}" width="${size}" height="${size}" style="display:block;">${paths}</svg>`;
}
