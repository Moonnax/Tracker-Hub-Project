  if(!items.length){list.innerHTML='<div style="padding:24px;text-align:center;color:var(--text-muted);font-size:12px;">Nenhum lembrete pendente 🎉</div>';return;}
  list.innerHTML=items.map(r=>'<div class="bell-item" onclick="closeBellPanel();openModal(\''+r.projId+'\')"><div class="bell-item-icon">📅</div><div class="bell-item-body"><div class="bell-item-proj">'+esc(r.proj||'—')+'</div><div class="bell-item-dt">'+fmtD(r.date)+(r.time?' às '+r.time:'')+'</div>'+(r.note?'<div class="bell-item-note">'+esc(r.note)+'</div>':'')+'</div></div>').join('');
}

