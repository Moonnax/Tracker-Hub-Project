    '<td style="width:100px">'+liveCell+'</td>'+
    '<td style="width:180px">'+lastCell+'</td>'+
    '<td style="white-space:nowrap;"><button class="btn btn-s btn-xs" onclick="event.stopPropagation();openQuickUpd(\''+p.id+'\')" type="button" title="Quick Update" style="background:transparent;">+ Update</button> <button class="btn btn-g btn-xs" onclick="event.stopPropagation();openModal(\''+p.id+'\')" type="button">Edit</button></td>'+
    '</tr>';
  }).join('');
  wrap.innerHTML='<div class="twrap"><table><thead><tr>'+
    '<th style="width:28px"></th>'+
    '<th class="sort'+sc('priority')+'" onclick="sortBy(\'priority\')">Priority</th>'+
    '<th class="sort'+sc('initiative')+'" onclick="sortBy(\'initiative\')">Initiative</th>'+
    '<th class="sort'+sc('status')+'" onclick="sortBy(\'status\')">Status</th>'+
    '<th class="sort'+sc('progress')+'" onclick="sortBy(\'progress\')">Progress</th>'+
    '<th class="sort'+sc('pm')+'" onclick="sortBy(\'pm\')">PM</th>'+
    '<th>Product Line</th>'+
    '<th class="sort'+sc('localETA')+'" onclick="sortBy(\'localETA\')" style="width:100px">Local ETA</th>'+
    '<th class="sort'+sc('liveETA')+'" onclick="sortBy(\'liveETA\')" style="width:100px">Live ETA</th>'+
    '<th style="width:180px">Last Update</th>'+
