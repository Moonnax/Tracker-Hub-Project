}

// ── LOGIN ──
function handleLoginClick(){
  if(currentUser){showLogoutConfirm();}else{showLoginModal();}
}
function showLoginModal(){
  const ul=document.getElementById('login-user-list');
  if(ul){
    ul.innerHTML=team.map(m=>{
      const lv=m.accessLevel||m.level||2;
      return'<div class="bar-sd-item" onclick="attemptLogin(\''+esc(m.name)+'\')" style="display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:8px;border:1.5px solid var(--border);cursor:pointer;margin-bottom:4px;">'+
        '<div style="width:32px;height:32px;border-radius:50%;background:var(--grad);color:#fff;font-weight:800;font-size:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">'+initials(m.name)+'</div>'+
        '<div style="flex:1;min-width:0;"><div style="font-weight:600;font-size:12px;color:var(--text-main);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+m.name+'</div><div style="font-size:10px;color:var(--text-sub);">'+(lv===1?'L1 — GPM / Director':'L2 — Team Lead')+'</div></div>'+
        '<span class="badge '+(lv===1?'p0':'p2')+'" style="font-size:9px;padding:1px 6px;">L'+lv+'</span>'+
      '</div>';
    }).join('');
  }
  document.getElementById('login-name-inp').value='';
  document.getElementById('login-err').textContent='';
  document.getElementById('login-modal').classList.remove('hidden');
  setTimeout(()=>document.getElementById('login-name-inp').focus(),200);
}
function doLogin(){
  const name=document.getElementById('login-name-inp').value.trim();
  if(!name){document.getElementById('login-err').textContent='Por favor digite seu nome.';return;}
  attemptLogin(name);
}
function attemptLogin(name){
  const m=team.find(x=>x.name.toLowerCase()===name.toLowerCase());
  if(!m){document.getElementById('login-err').textContent='Nome não encontrado. Verifique o nome.';return;}
  const lv=m.accessLevel||m.level||2;
  currentUser={name:m.name,level:lv};
  l2BannerDismissed=false;window._l1BannerDismissed=false;
  saveSession();
  closeOneModal('login-modal');
  updateLoginBtn();
  if(isL2()){MS['pm']=new Set([currentUser.name]);}
  // Refresh ALL tabs on login
  refreshAllTabs();
  toast('Bem-vindo, '+m.name+'! (L'+lv+')','success');
}
function showLogoutConfirm(){
  if(confirm('Sair como '+currentUser.name+'?')){
    clearSession();l2BannerDismissed=false;window._l1BannerDismissed=false;
    updateLoginBtn();MS={};customFilter=null;showStarredOnly=false;
    // Refresh ALL tabs on logout (show login wall)
    refreshAllTabs();
    toast('Sessão encerrada');
  }
}
function updateLoginBtn(){
  const btn=document.getElementById('bar-login-btn');
  const icon=document.getElementById('bar-login-icon');
  const lbl=document.getElementById('bar-login-label');
  if(!btn)return;
  if(currentUser){
    btn.classList.add('logged-in');
    icon.innerHTML='<div class="login-avatar">'+initials(currentUser.name)+'</div>';
    lbl.textContent=currentUser.name.split(' ')[0]+' (L'+currentUser.level+')';
  }else{
    btn.classList.remove('logged-in');
    icon.textContent='👤';lbl.textContent='Login';
  }
}

