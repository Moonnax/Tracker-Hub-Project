let tkTId=null,tkTEl=null,tkTClone=null;
function taskKTouchStart(e){const i=e.currentTarget;tkTId=i.dataset.id;tkTEl=i;const r=i.getBoundingClientRect();tkTClone=i.cloneNode(true);tkTClone.style.cssText='position:fixed;top:'+r.top+'px;left:'+r.left+'px;width:'+r.width+'px;opacity:.7;pointer-events:none;z-index:9999;border-radius:8px;background:#fff;box-shadow:0 4px 16px rgba(0,0,0,.2);';document.body.appendChild(tkTClone);i.style.opacity='.3';document.addEventListener('touchmove',taskKTouchMove,{passive:false});document.addEventListener('touchend',taskKTouchEnd);}
function taskKTouchMove(e){e.preventDefault();const t=e.touches[0];if(tkTClone){tkTClone.style.top=(t.clientY-20)+'px';tkTClone.style.left=(t.clientX-40)+'px';}document.querySelectorAll('.task-kcol').forEach(c=>c.classList.remove('drag-over'));document.elementFromPoint(t.clientX,t.clientY)?.closest('.task-kcol')?.classList.add('drag-over');}
function taskKTouchEnd(e){const t=e.changedTouches[0];document.querySelectorAll('.task-kcol').forEach(c=>c.classList.remove('drag-over'));if(tkTClone){tkTClone.remove();tkTClone=null;}if(tkTEl)tkTEl.style.opacity='';const col=document.elementFromPoint(t.clientX,t.clientY)?.closest('.task-kcol');if(col&&tkTId){const done=col.id==='kcol-done';const task=tasks.find(x=>x.id===tkTId);if(task&&task.done!==done){task.done=done;saveTasks();renderTasks();toast(done?'Marked done ✓':'Moved to pending');}}tkTId=null;tkTEl=null;document.removeEventListener('touchmove',taskKTouchMove);document.removeEventListener('touchend',taskKTouchEnd);}
function taskKDragStart(e){e.dataTransfer.setData('text/plain',e.currentTarget.dataset.id);e.currentTarget.classList.add('dragging');}
function taskKDragEnd(e){e.currentTarget.classList.remove('dragging');}
function taskKDragOver(e){e.preventDefault();e.currentTarget.classList.add('drag-over');}
function taskKDragLeave(e){e.currentTarget.classList.remove('drag-over');}
function taskKDrop(e,done){e.preventDefault();e.currentTarget.classList.remove('drag-over');const id=e.dataTransfer.getData('text/plain');const t=tasks.find(x=>x.id===id);if(t&&t.done!==done){t.done=done;saveTasks();renderTasks();toast(done?'Marked done ✓':'Moved to pending');}}
