// ── COMMAND PALETTE ──
let palIdx=0;
function openPalette(){document.getElementById('palette-bg').classList.remove('hidden');document.getElementById('pal-input').value='';renderPalette();setTimeout(()=>document.getElementById('pal-input').focus(),50);}
function closePalette(){document.getElementById('palette-bg').classList.add('hidden');}
function renderPalette(){
  const q=document.getElementById('pal-input').value.toLowerCase();
  const el=document.getElementById('pal-results');if(!el)return;
  const visProjects=getVisibleProjects(); // respects L2 filter
  const nav=[{i:'📊',t:'Dashboard',s:'Overview & heatmap',a:"closePalette();showTab('dashboard')"},{i:'📁',t:'Projects',s:'All '+visProjects.length+' projects',a:"closePalette();showTab('projects')"},{i:'📋',t:'Changelog',s:'Activity feed',a:"closePalette();showTab('changelog')"},{i:'👥',t:'Team',s:'Manage team',a:"closePalette();showTab('team')"},{i:'✅',t:'Tasks',s:'My tasks',a:"closePalette();showTab('tasks')"},{i:'📈',t:'Reports',s:'Analytics',a:"closePalette();showTab('reports')"},{i:'➕',t:'New Project',s:'Add project',a:"closePalette();openNewModal()"}];
  const mn=q?nav.filter(x=>x.t.toLowerCase().includes(q)||x.s.toLowerCase().includes(q)):nav;
  const mp=q?visProjects.filter(p=>(p.initiative||'').toLowerCase().includes(q)||(p.pm||'').toLowerCase().includes(q)).slice(0,8):visProjects.filter(p=>p.starred||p.priority==='P0').slice(0,6);
  palIdx=0;
  let html=mn.length?'<div class="pal-section-lbl">Navigation</div>'+mn.map((x,i)=>'<div class="pal-item '+(i===0&&!q?'active':'')+'" onclick="'+x.a+'"><span class="pal-item-icon">'+x.i+'</span><div class="pal-item-main"><div class="pal-item-title">'+x.t+'</div><div class="pal-item-sub">'+x.s+'</div></div></div>').join(''):'';
  if(mp.length)html+='<div class="pal-section-lbl">Projects</div>'+mp.map(p=>'<div class="pal-item" onclick="closePalette();openModal(\''+p.id+'\')"><span class="pal-item-icon">📁</span><div class="pal-item-main"><div class="pal-item-title">'+esc(p.initiative||'—')+'</div><div class="pal-item-sub">'+esc(p.pm||'—')+'</div></div><span class="badge '+pCls(p.priority)+'" style="font-size:10px">'+p.priority+'</span></div>').join('');
  if(!html)html='<div class="empty-state" style="padding:30px"><div class="empty-icon">🔍</div><div class="empty-sub">No results for "'+esc(q)+'"</div></div>';
  el.innerHTML=html;
}
function palKey(e){const items=document.querySelectorAll('.pal-item');if(e.key==='ArrowDown'){e.preventDefault();palIdx=Math.min(palIdx+1,items.length-1);}else if(e.key==='ArrowUp'){e.preventDefault();palIdx=Math.max(palIdx-1,0);}else if(e.key==='Enter'){items[palIdx]?.click();return;}else if(e.key==='Escape'){closePalette();return;}items.forEach((el,i)=>el.classList.toggle('active',i===palIdx));items[palIdx]?.scrollIntoView({block:'nearest'});}
function showShortcuts(){document.getElementById('shortcuts-modal').classList.remove('hidden');}

// ── TOAST & HELPERS ──
function toast(msg,type=''){const el=document.createElement('div');el.className='toast '+(type||'');el.textContent=(type==='success'?'✓ ':type==='error'?'✕ ':type==='warn'?'⚠ ':'')+msg;document.getElementById('toast-ct').appendChild(el);setTimeout(()=>el.remove(),3200);}
function emptyState(icon,title,sub,action,btnTxt){return'<div class="empty-state"><div class="empty-icon">'+icon+'</div><div class="empty-title">'+title+'</div><div class="empty-sub">'+sub+'</div>'+(action&&btnTxt?'<button class="btn btn-p btn-sm" onclick="'+action+'" type="button">'+btnTxt+'</button>':'')+'</div>';}
function closeOneModal(id){document.getElementById(id)?.classList.add('hidden');}

const MODAL_ORDER=['palette-bg','shortcuts-modal','admin-modal','team-modal','quick-upd-modal','proj-modal','login-modal'];
function closeTopModal(){
  // Check member-info-popup first (uses display, not hidden class)
  const mip=document.getElementById('member-info-popup');
  if(mip&&mip.style.display!=='none'){mip.style.display='none';return;}
  for(const id of MODAL_ORDER){const el=document.getElementById(id);if(el&&!el.classList.contains('hidden')){el.classList.add('hidden');if(id==='quick-upd-modal')quickUpdProjId=null;return;}}
}

// ── KEYBOARD ──
document.addEventListener('keydown',e=>{
  if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA'||e.target.isContentEditable)return;
  if((e.ctrlKey||e.metaKey)&&e.key==='k'){e.preventDefault();openPalette();return;}
  if(e.key==='?'){showShortcuts();return;}
  if(e.key==='Escape'){closeTopModal();return;}
  if(e.key==='n'||e.key==='N'){if(document.querySelector('.tab.on')?.id==='projects-tab')openNewModal();}
});
document.getElementById('palette-bg')?.addEventListener('click',e=>{if(e.target===e.currentTarget)closePalette();});
['proj-modal','admin-modal','team-modal','shortcuts-modal','login-modal','quick-upd-modal'].forEach(id=>{document.getElementById(id)?.addEventListener('click',e=>{if(e.target===e.currentTarget){e.currentTarget.classList.add('hidden');if(id==='quick-upd-modal')quickUpdProjId=null;}});});

