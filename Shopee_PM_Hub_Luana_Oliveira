// ── BELL / REMINDER NOTIFICATIONS ──
function getBellReminders(){
  const now=new Date();
  const visible=getVisibleProjects();
  const items=[];
  visible.forEach(p=>{
    (p.reminders||[]).forEach(r=>{
      if(!r.date)return;
      const dt=new Date(r.date+'T'+(r.time||'00:00')+':00');
      if(dt>=now){items.push({proj:p.initiative,projId:p.id,date:r.date,time:r.time||'',note:r.note||'',dt});}
    });
  });
  items.sort((a,b)=>a.dt-b.dt);
  return items;
}
function updateBellBadge(){
  if(!currentUser)return;
  const items=getBellReminders();
  const badge=document.getElementById('bell-badge');
  if(badge){
    if(items.length>0){badge.textContent=items.length>99?'99+':items.length;badge.classList.remove('hidden');}
    else{badge.classList.add('hidden');}
  }
}
function toggleBellPanel(){
  const panel=document.getElementById('bell-panel');
  if(!panel)return;
  if(panel.classList.contains('open')){closeBellPanel();return;}
  if(!currentUser){toast('Faça login para ver lembretes','warn');return;}
  renderBellPanel();
  panel.classList.add('open');
  document.addEventListener('click',bellOutsideClick,{once:true});
}
function closeBellPanel(){
  const panel=document.getElementById('bell-panel');
  if(panel)panel.classList.remove('open');
}
function bellOutsideClick(e){
  const panel=document.getElementById('bell-panel');
  const btn=document.getElementById('bell-btn');
  if(panel&&!panel.contains(e.target)&&btn&&!btn.contains(e.target)){closeBellPanel();}
  else if(panel&&panel.classList.contains('open')){document.addEventListener('click',bellOutsideClick,{once:true});}
}
function renderBellPanel(){
  const list=document.getElementById('bell-list');if(!list)return;
