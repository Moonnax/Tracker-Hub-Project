// ── CHANGELOG COMMENTS ──
const STORE_COMMENTS='sph_comments3';
function loadComments(){try{return JSON.parse(localStorage.getItem(STORE_COMMENTS))||{};}catch(e){return{};}}
function saveComments(data){localStorage.setItem(STORE_COMMENTS,JSON.stringify(data));}
let commentsData=loadComments();

function renderCommentThread(comments,projId,updateId){
  if(!comments||!comments.length)return'';
  return'<div class="cl-comment-thread">'+comments.map((c,ci)=>{
    const isDone=c.done;
    // L2 can mark done if comment came from L1; L1 cannot mark done
    const showDoneBtn=isL2()&&!isDone&&c.fromLevel===1&&currentUser;
    // Build flat reply chain
    const repliesHtml=(c.replies&&c.replies.length)?
      '<div class="cl-reply-chain">'+c.replies.map((r,ri)=>'<div class="cl-reply-bubble '+(r.fromLevel===1?'cl-reply-l1':'cl-reply-l2')+'"><div class="cl-comment-meta"><span class="cl-comment-author" style="color:'+(r.fromLevel===1?'var(--or)':'#1D4ED8')+'">'+esc(r.author||'')+'</span><span class="cl-comment-date">'+esc(r.date||'')+'</span></div><div class="cl-comment-text">'+esc(r.text||'')+'</div></div>').join('')+'</div>':'';
    // Who can reply: L1 always (if not done), L2 if not done
    const canReply=!isDone&&currentUser;
    const replyInputId='rep-'+updateId+'-'+ci;
    return'<div class="cl-comment-item '+(isDone?'cl-comment-closed':'')+'">'+
      '<div class="cl-comment-meta"><span class="cl-comment-author" style="color:'+(c.fromLevel===1?'var(--or)':'#1D4ED8')+'">'+esc(c.author||'L1')+'</span><span class="cl-comment-date">'+esc(c.date||'')+'</span>'+(isDone?'<span style="font-size:10px;color:#065F46;font-weight:700;margin-left:4px;">✓ Done</span>':'')+'</div>'+
      '<div class="cl-comment-text">'+esc(c.text||'')+'</div>'+
      repliesHtml+
      (!isDone?'<div style="display:flex;gap:6px;margin-top:6px;align-items:center;">'+
        (showDoneBtn?'<button type="button" class="cl-comment-done" onclick="markCommentDone(\''+projId+'\',\''+updateId+'\','+ci+')">✓ Done</button>':'')+
        (canReply?'<button type="button" class="cl-comment-btn" style="font-size:10px;padding:2px 8px;height:auto;" onclick="toggleCommentInput(\''+replyInputId+'\')">↩ Reply</button>':'')+
      '</div>':'')+
      (canReply?'<div id="'+replyInputId+'" style="display:none;margin-top:6px;">'+
        '<textarea class="cl-reply-inp" id="'+replyInputId+'-txt" rows="2" placeholder="Responder..."></textarea>'+
        '<div class="cl-reply-row"><button type="button" class="btn btn-p btn-xs" onclick="submitReply(\''+projId+'\',\''+updateId+'\','+ci+')">Enviar</button><button type="button" class="btn btn-g btn-xs" onclick="toggleCommentInput(\''+replyInputId+'\')">Cancelar</button></div>'+
      '</div>':'')+
      '</div>';
  }).join('')+'</div>';
}

function toggleCommentInput(id){
  const el=document.getElementById(id);
  if(el){el.style.display=el.style.display==='none'?'block':'none';}
}
function toggleClItem(collapseId){
  const el=document.getElementById(collapseId);
  const arr=document.getElementById('arr-'+collapseId);
  if(!el)return;
  const isHidden=el.classList.contains('hidden');
  el.classList.toggle('hidden',!isHidden);
  if(arr){arr.style.transform=isHidden?'rotate(90deg)':'rotate(0deg)';}
}

// Helper: re-renders only the comment thread inside a specific collapsible, keeping it open
function _refreshCommentThread(projId,updateId,comments){
  // Find the collapsible div for this update (search by data or by updateId in child ids)
  // The comment thread lives inside a div whose id starts with 'cle-' and contains the updateId
  const allCollapsibles=document.querySelectorAll('.cl-collapsible');
  let targetCollapsible=null;
  allCollapsibles.forEach(el=>{
    // check if this collapsible has a child with id containing the updateId
    if(el.querySelector('[id*="'+updateId+'"]')||el.id.includes(updateId))targetCollapsible=el;
  });
  if(!targetCollapsible){renderChangelog();return;} // fallback
  // Re-render comment thread HTML in-place
  const threadHtml=renderCommentThread(comments,projId,updateId);
  // Find and replace existing thread (or prepend)
  const existingThread=targetCollapsible.querySelector('.cl-comment-thread');
  if(existingThread){existingThread.outerHTML=threadHtml||'';}
  else if(threadHtml){targetCollapsible.insertAdjacentHTML('afterbegin',threadHtml);}
  // Hide the comment input if it's showing (user just sent)
  const ci=document.getElementById('ci-'+updateId);
  if(ci){ci.style.display='none';}
  const ciTxt=document.getElementById('ci-txt-'+updateId);
  if(ciTxt)ciTxt.value='';
}

function submitComment(projId,updateId){
  const txtEl=document.getElementById('ci-txt-'+updateId);
  if(!txtEl)return;
  const txt=txtEl.value.trim();
  if(!txt){toast('Escreva o comentário primeiro','warn');return;}
  if(!currentUser){toast('Login necessário','error');return;}
  const p=projects.find(x=>x.id===projId);if(!p)return;
  const u=(p.weeklyUpdates||[]).find(x=>x.id===updateId);
  if(!u){toast('Update não encontrado','error');return;}
  if(!u.comments)u.comments=[];
  u.comments.push({text:txt,author:currentUser.name,date:new Date().toISOString().slice(0,10),fromLevel:currentUser.level,done:false,replies:[]});
  saveP();
  _refreshCommentThread(projId,updateId,u.comments);
  toast('Comentário enviado ✓','success');
}

function submitReply(projId,updateId,commentIdx){
  const replyInputId='rep-'+updateId+'-'+commentIdx;
  const txtEl=document.getElementById(replyInputId+'-txt');
  if(!txtEl)return;
  const txt=txtEl.value.trim();
  if(!txt){toast('Escreva a resposta primeiro','warn');return;}
  if(!currentUser){toast('Login necessário','error');return;}
  const p=projects.find(x=>x.id===projId);if(!p)return;
  const u=(p.weeklyUpdates||[]).find(x=>x.id===updateId);if(!u)return;
  if(!u.comments||!u.comments[commentIdx])return;
  if(!u.comments[commentIdx].replies)u.comments[commentIdx].replies=[];
  u.comments[commentIdx].replies.push({text:txt,author:currentUser.name,date:new Date().toISOString().slice(0,10),fromLevel:currentUser.level});
  saveP();
  _refreshCommentThread(projId,updateId,u.comments);
  toast('Resposta enviada ✓','success');
}

function markCommentDone(projId,updateId,commentIdx){
  const p=projects.find(x=>x.id===projId);if(!p)return;
  const u=(p.weeklyUpdates||[]).find(x=>x.id===updateId);if(!u)return;
  if(!u.comments||!u.comments[commentIdx])return;
  u.comments[commentIdx].done=true;
  saveP();
  _refreshCommentThread(projId,updateId,u.comments);
  toast('Marcado como resolvido ✓','success');
}

