function pOrd(p){return PRIO_ORD[p]??5;}
function sOrd(s){return STAT_ORD[s]??99;}
function sCls(s){return 's'+(s||'').replace(/[\s\/]/g,'_');}
function pCls(p){return p==='P0'?'p0':p==='P1'?'p1':p==='P2'?'p2':p==='P3'?'p3':'ptd';}
function progPct(s){const i=PIPE.findIndex(x=>x.ss.includes(s));return i<0?0:Math.round((i+1)/PIPE.length*100);}
function esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function stripHtml(s){return(s||'').replace(/<[^>]*>/g,'');}
function initials(n){if(!n)return'?';const w=n.trim().split(' ');return(w[0][0]+(w[1]?w[1][0]:'')).toUpperCase();}
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2);}
function fmtD(d){
  if(!d||d==='')return'—';
  if(d==='NA'||d==='N/A'||d==='-')return d;
  const x=new Date(d+'T00:00:00');
  if(!isNaN(x.getTime())){const MN=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];return String(x.getDate()).padStart(2,'0')+'/'+MN[x.getMonth()]+'/'+String(x.getFullYear()).slice(2);}
  return d;
}
function safeDate(d){
  if(!d||d===''||d==='NA'||d==='N/A'||d==='-')return null;
  const x=new Date(d+'T00:00:00');return isNaN(x.getTime())?null:x;
}
function getQ(ds){const d=safeDate(ds);return d?'Q'+Math.floor(d.getMonth()/3+1)+' '+d.getFullYear():null;}
function mLabel(mk){if(!mk)return'';const[y,m]=mk.split('-');const N=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];return N[parseInt(m)-1]+' '+y;}

