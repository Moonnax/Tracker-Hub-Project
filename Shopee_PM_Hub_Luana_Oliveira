function renderRoadmap(filtered){
  const el=document.getElementById('proj-roadmap');if(!el)return;
  if(!filtered.length){el.innerHTML=emptyState('📅','No projects found','Try adjusting your filters.','clearAllFilters()','Clear Filters');return;}
  const active=filtered.filter(p=>!FROZEN.includes(p.status));
  const qtrs=new Set();const today=new Date();const curQ='Q'+(Math.floor(today.getMonth()/3)+1)+' '+today.getFullYear();
  active.forEach(p=>{const q1=getQ(p.localETA),q2=getQ(p.liveETA);if(q1)qtrs.add(q1);if(q2)qtrs.add(q2);});
  for(let i=0;i<6;i++){const d=new Date(today.getFullYear(),today.getMonth()+i*3,1);qtrs.add('Q'+(Math.floor(d.getMonth()/3)+1)+' '+d.getFullYear());}
  const sortedQ=[...qtrs].sort((a,b)=>{const[qa,ya]=a.split(' ');const[qb,yb]=b.split(' ');return parseInt(ya)*4+parseInt(qa[1])-(parseInt(yb)*4+parseInt(qb[1]));});
  const rows_by=rmGroup==='pm'?[...new Set(active.map(p=>p.pm).filter(Boolean))].sort():[...new Set(active.map(p=>p.productLine).filter(Boolean))].sort();
  if(!rows_by.length){el.innerHTML=emptyState('📅','No roadmap data','Add projects with Live ETA.','openNewModal()','Add Project');return;}
  const tbd=active.filter(p=>!getQ(p.liveETA)&&!getQ(p.localETA));
  const rows=rows_by.map(key=>{
    const rps=active.filter(p=>rmGroup==='pm'?p.pm===key:p.productLine===key);
    const cells=sortedQ.map(q=>{
      const qps=rps.filter(p=>{const qLive=getQ(p.liveETA),qLocal=getQ(p.localETA);const start=qLocal||qLive,end=qLive||qLocal;if(!start||!end)return false;const qs=[start,end].sort((a,b)=>{const[qa,ya]=a.split(' ');const[qb,yb]=b.split(' ');return parseInt(ya)*4+parseInt(qa[1])-(parseInt(yb)*4+parseInt(qb[1]));});const sq=sortedQ.indexOf(qs[0]),eq=sortedQ.indexOf(qs[1]),cq=sortedQ.indexOf(q);return sq>=0&&eq>=0&&cq>=sq&&cq<=eq;});
      return'<td class="rm-cell'+(q===curQ?' cur':'')+'">'+(qps.map(p=>'<span class="rm-chip '+(p.priority==='P0'?'p0-chip':p.status==='Live'?'live-chip':'')+'" onclick="openModal(\''+p.id+'\')" title="'+esc(p.initiative||'')+'">'+esc((p.initiative||'—').slice(0,22))+'</span>').join(''))+'</td>';
    }).join('');
    const tbdPs=tbd.filter(p=>rmGroup==='pm'?p.pm===key:p.productLine===key);
    const tbdCell='<td class="rm-cell" style="background:#F8F9FB;">'+tbdPs.map(p=>'<span class="rm-chip" onclick="openModal(\''+p.id+'\')" title="'+esc(p.initiative||'')+'">'+esc((p.initiative||'—').slice(0,22))+'</span>').join('')+'</td>';
    return'<tr><td class="rm-row-cell">'+esc(key||'Unassigned')+'</td>'+cells+tbdCell+'</tr>';
  }).join('');
  const hdrs=sortedQ.map(q=>'<th class="rm-hd'+(q===curQ?' cur':'')+'" style="'+(q===curQ?'background:var(--ord)':'')+' ">'+q+'</th>').join('');
  el.innerHTML='<table class="roadmap-tbl"><thead><tr><th class="rm-hd rm-row-hd">'+(rmGroup==='pm'?'PM':'Product Line')+'</th>'+hdrs+'<th class="rm-hd" style="background:var(--dg)">TBD / No ETA</th></tr></thead><tbody>'+rows+'</tbody></table>';
}

