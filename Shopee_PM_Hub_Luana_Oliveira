function isL1(){return!currentUser||currentUser.level===1;}
function isL2(){return currentUser&&currentUser.level===2;}

function getVisibleProjects(){
  if(isL2())return projects.filter(p=>p.pm===currentUser.name);
  return projects;
}
function getVisibleTasks(){
  if(isL2())return tasks.filter(t=>!t.owner||t.owner===currentUser.name);
