function buildFilters(){
  const pms=[...new Set(projects.map(p=>p.pm).filter(Boolean))].sort();
  const lines=[...new Set(projects.map(p=>p.productLine).filter(Boolean))].sort();
  const statuses=[...new Set(projects.map(p=>p.status).filter(Boolean))].sort();
