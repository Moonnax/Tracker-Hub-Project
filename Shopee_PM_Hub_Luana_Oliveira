}
function toggleRow(id){
  const exp=document.getElementById('exp-'+id);if(!exp)return;
  const isOpen=exp.style.display!=='none';
  document.querySelectorAll('[id^="exp-"]').forEach(r=>r.style.display='none');
  document.querySelectorAll('tbody tr').forEach(r=>r.classList.remove('expanded'));
  if(!isOpen){const p=projects.find(x=>x.id===id);if(!p)return;exp.style.display='';document.getElementById('tr-'+id)?.classList.add('expanded');document.getElementById('exp-body-'+id).innerHTML=buildExpand(p);}
}
function buildExpand(p){
  if(!p)return'';
