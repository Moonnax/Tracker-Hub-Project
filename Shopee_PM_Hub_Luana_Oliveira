    '<div class="task-kcol" id="kcol-done" ondragover="taskKDragOver(event)" ondrop="taskKDrop(event,true)" ondragleave="taskKDragLeave(event)"><div class="task-kcol-hd">✅ Done <span class="task-kcnt">'+done.length+'</span></div>'+(done.map(kCard).join('')||'<div class="text-muted" style="text-align:center;padding:20px">Drop tasks here</div>')+'</div>'+
  '</div>';
