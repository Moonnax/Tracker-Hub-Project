  fb.innerHTML=
    '<div class="fg"><label>Search</label><input class="search-inp" id="proj-search" placeholder="Search projects..." oninput="renderProjects()"></div>'+
    '<div class="fg"><label>Status</label>'+buildMS('status','Status',statuses)+'</div>'+
    '<div class="fg"><label>Priority</label>'+buildMS('priority','Priority',['P0','P1','P2','P3','To define'])+'</div>'+
    '<div class="fg"><label>PM</label>'+buildMS('pm','PM',pms)+'</div>'+
    '<div class="fg"><label>Line</label>'+buildMS('line','Line',lines)+'</div>'+
    '<div class="fg"><label>Sort</label><select id="sort-by-sel" onchange="renderProjects()" style="height:var(--h);font-size:12px;min-width:165px;"><option value="">Default (Priority)</option><option value="lastupdate">🕐 Most Recent Update</option><option value="oldestupdated">🕰 Oldest / No Update</option></select></div>'+
    '<div class="fg" style="justify-content:flex-end;"><label>&nbsp;</label><button class="star-filter-btn '+(showStarredOnly?'active':'')+'" onclick="toggleStarFilter()" type="button">⭐ Favorites'+(showStarredOnly?' ✓':'')+'</button></div>'+
    (isL2()?'<div class="fg" style="justify-content:flex-end;"><label>&nbsp;</label><span style="font-size:10px;font-weight:700;color:#1D4ED8;background:#EFF6FF;border:1px solid #93C5FD;border-radius:var(--rs);padding:0 10px;height:var(--h);display:flex;align-items:center;gap:4px;">👤 Filtro: '+esc(currentUser.name)+'</span></div>':'')+
    '<div class="fg" style="justify-content:flex-end;"><label>&nbsp;</label><button class="btn btn-g btn-sm" onclick="clearAllFilters()" type="button" style="height:var(--h);">Clear</button></div>';
}
function toggleStarFilter(){showStarredOnly=!showStarredOnly;buildFilters();renderProjects();}
function clearAllFilters(){
  customFilter=null;MS={};showStarredOnly=false;
  if(isL2())MS['pm']=new Set([currentUser.name]);
  const s=document.getElementById('proj-search');if(s)s.value='';
  buildFilters();renderProjects();
}
function getFiltered(){
  let base=customFilter?projects.filter(customFilter):projects;
  if(showStarredOnly)base=base.filter(p=>p.starred);
  const q=(document.getElementById('proj-search')?.value||'').toLowerCase();
  const sts=getMS('status'),pris=getMS('priority'),pms=getMS('pm'),lns=getMS('line');
  const sortOpt=document.getElementById('sort-by-sel')?.value||'';
  const res=base.filter(p=>{
    if(q&&!((p.initiative||'').toLowerCase().includes(q)||(p.description||'').toLowerCase().includes(q)||(p.pm||'').toLowerCase().includes(q)||(p.productLine||'').toLowerCase().includes(q)))return false;
    if(sts.length&&!sts.includes(p.status))return false;
    if(pris.length&&!pris.includes(p.priority))return false;
    if(pms.length&&!pms.includes(p.pm))return false;
    if(lns.length&&!lns.includes(p.productLine))return false;
    return true;
  });
  return res.sort((a,b)=>{
    if(sortOpt==='lastupdate'){const au=(a.weeklyUpdates||[]).slice(-1)[0],bu=(b.weeklyUpdates||[]).slice(-1)[0];const ad=au&&typeof au==='object'?au.date||'':'',bd=bu&&typeof bu==='object'?bu.date||'':'';if(ad>bd)return-1;if(ad<bd)return 1;return 0;}
    if(sortOpt==='oldestupdated'){const au=(a.weeklyUpdates||[]).slice(-1)[0],bu=(b.weeklyUpdates||[]).slice(-1)[0];const ad=au&&typeof au==='object'?au.date||'':'',bd=bu&&typeof bu==='object'?bu.date||'':'';if(ad<bd)return-1;if(ad>bd)return 1;return 0;}
    let av,bv;
    if(sortCol==='priority'){av=pOrd(a.priority);bv=pOrd(b.priority);}
    else if(sortCol==='status'){av=sOrd(a.status);bv=sOrd(b.status);}
    else if(sortCol==='initiative'){av=(a.initiative||'').toLowerCase();bv=(b.initiative||'').toLowerCase();}
    else if(sortCol==='pm'){av=(a.pm||'').toLowerCase();bv=(b.pm||'').toLowerCase();}
    else if(sortCol==='liveETA'){av=a.liveETA||'';bv=b.liveETA||'';}
    else{av=a[sortCol]||'';bv=b[sortCol]||'';}
    if(av<bv)return-sortDir;if(av>bv)return sortDir;return 0;
  });
}

function setView(v){curView=v;['table','board','roadmap'].forEach(x=>{document.getElementById('view-'+x).classList.toggle('hidden',x!==v);document.getElementById('vbtn-'+x).classList.toggle('on',x===v);});renderProjects();}

function renderProjects(){
  if(!currentUser){
    // Sem login: esconde todos os controles, mostra só login wall
    document.querySelectorAll('#projects-tab .view-controls').forEach(el=>el.style.display='none');
    const fbar=document.getElementById('proj-fbar');if(fbar)fbar.innerHTML='';
    document.getElementById('proj-table-wrap').innerHTML=loginWallHTML();
    document.getElementById('proj-board').innerHTML='';
    document.getElementById('proj-roadmap').innerHTML='';
    const info=document.getElementById('proj-info');if(info)info.textContent='';
    const nc=document.getElementById('nc-projects');if(nc)nc.textContent='';
    return;
  }
  // Logado: garante que controles estão visíveis
  document.querySelectorAll('#projects-tab .view-controls').forEach(el=>el.style.display='');
  const filtered=getFiltered();
  const info=document.getElementById('proj-info');
  const nc=document.getElementById('nc-projects');
  // FIX 4: L2 vê "X of X" (só os seus); L1 vê "X of total"
  const visibleBase=isL2()?getVisibleProjects():projects;
  if(info)info.textContent=filtered.length+' of '+visibleBase.length;
  // Aba Projects: L2 mostra só os seus; L1 mostra total
  if(nc){nc.textContent=isL2()?visibleBase.length:projects.length;}
  if(curView==='table')renderTable(filtered);
  else if(curView==='board')renderBoard(filtered);
  else renderRoadmap(filtered);
}

