  const wall=document.getElementById('cl-login-wall');if(wall)wall.innerHTML='';

  // ── PM FILTER: only L1 ──
  const pmFilterEl=document.getElementById('cl-pm-filter');
  if(pmFilterEl){
    if(isL2()){pmFilterEl.style.display='none';clPmFilterValue='';}
    else{
      pmFilterEl.style.display='';
      const pms=[...new Set(projects.map(p=>p.pm).filter(Boolean))].sort();
