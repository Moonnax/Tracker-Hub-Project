      pmFilterEl.innerHTML='<option value="">All PMs</option>'+pms.map(pm=>'<option value="'+esc(pm)+'" '+(pm===cur?'selected':'')+'>'+esc(pm)+'</option>').join('');
    }
  }

  // ── PROJECT FILTER: L1+L2, scoped by PM filter ──
  const projFilterEl=document.getElementById('cl-proj-filter');
  if(projFilterEl){
    const baseProj=isL2()?getVisibleProjects():projects;
    const scopedProj=clPmFilterValue?baseProj.filter(p=>p.pm===clPmFilterValue):baseProj;
    const withUpdates=scopedProj.filter(p=>p.weeklyUpdates&&p.weeklyUpdates.length>0);
    if(clProjectFilter&&!withUpdates.some(p=>p.id===clProjectFilter))clProjectFilter='';
    projFilterEl.innerHTML='<option value="">All Projects</option>'+withUpdates.map(p=>'<option value="'+esc(p.id)+'" '+(p.id===clProjectFilter?'selected':'')+'>'+esc((p.initiative||'—').slice(0,40))+'</option>').join('');
  }

  const filterPm=clPmFilterValue;
  const filterProj=clProjectFilter;
  const entries=[];
  const changelogSource=isL2()?getVisibleProjects():projects;
  changelogSource.forEach(p=>{
    if(filterPm&&p.pm!==filterPm)return;
    if(filterProj&&p.id!==filterProj)return;
    (p.weeklyUpdates||[]).forEach(u=>{
      const ud=typeof u==='object'?u.date||'':'';
      const ut=typeof u==='object'?(u.content||u.text||''):String(u);
      if(ut)entries.push({date:ud,project:p.initiative,pm:p.pm,id:p.id,text:ut,status:p.status,updateId:typeof u==='object'?u.id||'':'',comments:typeof u==='object'?u.comments||[]:[]}); 
    });
  });
  entries.sort((a,b)=>b.date.localeCompare(a.date));
  if(!entries.length){el.innerHTML=emptyState('📋','No updates yet','Add weekly updates to your projects.','showTab(\'projects\')','Go to Projects');return;}
  el.innerHTML=entries.slice(0,80).map((e,i)=>{
    const showCommentBtn=isL1()&&e.updateId;
    const hasComments=e.comments&&e.comments.length>0;
    const commentsHtml=hasComments?renderCommentThread(e.comments,e.id,e.updateId):'';
    const commentBtnHtml=showCommentBtn?'<button type="button" class="cl-comment-btn" onclick="toggleCommentInput(\'ci-'+e.updateId+'\')" title="Comentar neste update">💬 Comment</button>':'';
    const commentInputHtml=(showCommentBtn||hasComments)?'<div id="ci-'+e.updateId+'" style="display:none;margin-top:8px;"><textarea class="cl-reply-inp" id="ci-txt-'+e.updateId+'" rows="2" placeholder="Escreva um comentário para '+esc(e.pm||'PM')+'..."></textarea><div class="cl-reply-row"><button type="button" class="btn btn-p btn-xs" onclick="submitComment(\''+e.id+'\',\''+e.updateId+'\')">Enviar</button><button type="button" class="btn btn-g btn-xs" onclick="toggleCommentInput(\'ci-'+e.updateId+'\')">Cancelar</button></div></div>':'';
    const collapseId='cle-'+i+'-'+(e.updateId||i);
    const hasExtra=commentsHtml||commentBtnHtml||commentInputHtml;
    return'<div class="cl-item" style="animation-delay:'+i*15+'ms"><div class="cl-dot-col"><div class="cl-dot"></div><div class="cl-line"></div></div>'+
      '<div class="cl-body'+(hasExtra?' cl-body-clickable':'')+'\" '+(hasExtra?'onclick=\"toggleClItem(\''+collapseId+'\')"':'')+'>'+
        '<div class="cl-meta">'+
          '<span class="cl-date">'+(e.date||'No date')+'</span>'+
          '<span class="cl-proj" onclick="event.stopPropagation();openModal(\''+e.id+'\')">'+esc(e.project||'—')+'</span>'+
          '<span class="cl-pm-tag">'+esc(e.pm||'—')+'</span>'+
          '<span class="badge '+sCls(e.status)+'" style="font-size:10px">'+e.status+'</span>'+
          (hasExtra?'<span class="cl-toggle-arrow" id="arr-'+collapseId+'" style="margin-left:auto;font-size:11px;color:var(--text-muted);transition:transform .2s;display:inline-block;flex-shrink:0;">▶</span>':'')+
        '</div>'+
        '<div class="cl-text">'+e.text+'</div>'+
        (hasExtra?'<div id="'+collapseId+'" class="cl-collapsible hidden" onclick="event.stopPropagation()">'+commentsHtml+commentInputHtml+(commentBtnHtml?'<div style="margin-top:6px;">'+commentBtnHtml+'</div>':'')+'</div>':'')+
      '</div></div>';
  }).join('');
}

function generateReleaseNotes(){
  const entries=[];
  projects.forEach(p=>{(p.weeklyUpdates||[]).forEach(u=>{const ud=typeof u==='object'?u.date||'':'';const ut=typeof u==='object'?(u.content||u.text||''):String(u);if(ut)entries.push({date:ud,project:p.initiative,pm:p.pm,text:stripHtml(ut)});});});
  entries.sort((a,b)=>b.date.localeCompare(a.date));
  if(!entries.length){toast('No updates to generate from','warn');return;}
  const byWk={};entries.slice(0,30).forEach(e=>{const w=e.date.slice(0,7)||'Unknown';if(!byWk[w])byWk[w]=[];byWk[w].push(e);});
  let notes='# Release Notes — '+new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})+'\n\n';
  Object.entries(byWk).sort((a,b)=>b[0].localeCompare(a[0])).forEach(([w,es])=>{notes+='## '+mLabel(w)+'\n';es.forEach(e=>{notes+='- ['+e.pm+'] '+e.project+': '+e.text.slice(0,120)+'\n';});notes+='\n';});
  const box=document.getElementById('cl-rn-box');
  if(box){box.innerHTML='<div class="card"><div class="ctitle">📄 Release Notes<button class="btn btn-g btn-xs" style="margin-left:auto" onclick="navigator.clipboard.writeText(document.getElementById(\'rn-txt\').textContent).then(()=>toast(\'Copied!\',\'success\'))">Copy</button></div><pre class="rn-box" id="rn-txt">'+notes+'</pre></div>';box.classList.remove('hidden');}
  toast('Release notes generated!','success');
}

